{
	"name": "collection-data-anonymizer",
	"description": "Anonymize collection data with realistic fake values (names, emails, addresses, etc.) for dev/staging.",
	"icon": "extension",
	"version": "1.0.0",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-module"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "module",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^10.10.0"
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.0.11",
		"typescript": "^5.9.3",
		"vue": "^3.5.30"
	}
